{
  "name": "Günlük Piyasa Botu",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * *"
            }
          ]
        }
      },
      "name": "Zamanlayici",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position":
    },
    {
      "parameters": {
        "url": "https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd",
        "options": {}
      },
      "name": "Kripto Fiyatlarini Cek",
      "type": "n8n-nodes-base.httpRequest",
      "position":
    },
    {
      "parameters": {
        "jsCode": "const btc = $input.all().json.bitcoin.usd;\nconst eth = $input.all().json.ethereum.usd;\n\nreturn {\n  json: {\n    mesaj: `Günaydın! Güncel Fiyatlar:\\nBitcoin: $${btc}\\nEthereum: $${eth}`\n  }\n};"
      },
      "name": "Veriyi Duzenle",
      "type": "n8n-nodes-base.code",
      "position":
    },
    {
      "parameters": {
        "chatId": "SENIN_TELEGRAM_CHAT_ID_BURAYA",
        "text": "={{ $json.mesaj }}",
        "additionalFields": {}
      },
      "name": "Telegram'a Gonder",
      "type": "n8n-nodes-base.telegram",
      "position":
    }
  ],
  "connections": {
    "Zamanlayici": {
      "main": [
        [
          {
            "node": "Kripto Fiyatlarini Cek",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Kripto Fiyatlarini Cek": {
      "main": [
        [
          {
            "node": "Veriyi Duzenle",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Veriyi Duzenle": {
      "main": [
        [
          {
            "node": "Telegram'a Gonder",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false
}